# Supabase — get these from your Supabase project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# This is the "Publishable key" (anon key) — safe for client-side use
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-key

# Demo account — shown as a one-click login button on the login page (testing only).
# Leave unset in production to hide the button entirely.
NEXT_PUBLIC_DEMO_EMAIL=demo@example.com
NEXT_PUBLIC_DEMO_PASSWORD=your-demo-password
